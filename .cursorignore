# Cursor AI indexing ignore patterns
# Files and directories listed here will not be indexed by Cursor for AI context

# ============================================
# Dependencies & Build Artifacts
# ============================================
node_modules/
dist/
build/
coverage/
.next/
.turbo/
*.tsbuildinfo

# ============================================
# Rust/Tauri Build Artifacts
# ============================================
src-tauri/target/
src-tauri/WixTools314/
src-tauri/NSIS/
src-tauri/bin/
*.exe

# ============================================
# Large Model Files (No need for AI context)
# ============================================
*.gguf
*.ggml
*.safetensors
*.onnx
*.onnx.data
src-tauri/model/

# ============================================
# Log Files & Temporary Files
# ============================================
*.log
*storybook.log
npminstall-debug.log
*.swp
*.swo
*.tmp

# ============================================
# Data & Runtime Directories
# ============================================
/data/
/log/
None/

# ============================================
# Lock Files (Generated, no need for context)
# ============================================
package-lock.json
yarn.lock
pnpm-lock.yaml
init.lock

# ============================================
# IDE & OS Files
# ============================================
.DS_Store
**/.DS_Store
Thumbs.db
.history

# ============================================
# Python (if any)
# ============================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.Python
venv/
.venv/

# ============================================
# Reference & Test Files (Not production code)
# ============================================
_reference_sharer/
_reference_sharer_src/
_internal/
_symlinks/
Atlas/

# ============================================
# Machine-Specific & Local Config
# ============================================
.orgiiproject/
.atlasxp/
.worktrees/
ORG2 Helper (Backend)-*
src-tauri/bin/ORG2 Helper (Semantic)-*
ORGII Helper (Backend)-*
src-tauri/bin/ORGII Helper (Semantic)-*
src-tauri/sidecar/browser-server/node_modules/

# ============================================
# Compressed Archives
# ============================================
*.zip
*.tar.gz
*.rar

# ============================================
# Sensitive & Environment Files
# ============================================
encoded_key.txt
.env.local

# ============================================
# Documentation Build Output (Optional)
# ============================================
# Uncomment if you have auto-generated docs that shouldn't be indexed
# docs/.vitepress/dist/
# docs/.vitepress/cache/

# ============================================
# Test Output & Coverage (Optional)
# ============================================
# Uncomment if these directories are too large
# test-results/
# playwright-report/
# .nyc_output/
