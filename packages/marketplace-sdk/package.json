{
  "name": "@orgii/marketplace-sdk",
  "version": "0.2.0",
  "description": "SDK for building and consuming agent apps on the ORGII Marketplace, built on Google A2A protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "a2a",
    "agent",
    "marketplace",
    "orgii",
    "delegation"
  ],
  "license": "MIT",
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "uuid": "^11.1.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "peerDependencies": {
    "express": "^4.21.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
