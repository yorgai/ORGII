{
  "entry": ["src/index.tsx"],
  "extensions": [".ts", ".tsx", ".js", ".jsx"],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/*.d.ts",
    "**/types.ts",
    "**/config.ts",
    "**/exports.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/scripts/**"
  ],
  "ignoreUnresolved": ["@src/*", "@/*"],
  "moduleDirectory": ["node_modules", "src"],
  "aliases": {
    "@src/*": ["src/*"],
    "@/*": ["src/*"]
  }
}
